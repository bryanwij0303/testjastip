{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "invoice.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/admin/:path*", "dest": "/api/index.js" },
    { "src": "/api/orders", "dest": "/api/index.js" },
    { "src": "/api/tracker", "dest": "/api/index.js" },
    { "src": "/invoice.html", "dest": "/invoice.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
