{
  "version": 2,
  "builds": [
    { "src": "api/orders.js", "use": "@vercel/node" },
    { "src": "api/tracker.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "invoice.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/admin/(.*)", "dest": "/api/admin.js" },
    { "src": "/api/tracker", "dest": "/api/tracker.js" },
    { "src": "/api/orders", "dest": "/api/orders.js" },
    { "src": "/invoice.html", "dest": "/invoice.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
