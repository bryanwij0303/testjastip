{
  "version": 2,
  "builds": [
    { "src": "api/health.js", "use": "@vercel/node" },
    { "src": "api/envcheck.js", "use": "@vercel/node" },
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "invoice.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/envcheck", "dest": "/api/envcheck.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/invoice.html", "dest": "/invoice.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
